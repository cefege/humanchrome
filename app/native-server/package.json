{
  "name": "humanchrome-bridge",
  "version": "1.0.0",
  "description": "Native-messaging host that connects HumanChrome to AI clients over MCP or plain HTTP.",
  "homepage": "https://github.com/cefege/humanchrome",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cefege/humanchrome.git",
    "directory": "app/native-server"
  },
  "bugs": {
    "url": "https://github.com/cefege/humanchrome/issues"
  },
  "main": "dist/index.js",
  "bin": {
    "humanchrome-bridge": "./dist/cli.js",
    "humanchrome-stdio": "./dist/mcp/mcp-server-stdio.js"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext ts,js,json --ignore dist/ --exec \"npm run build && npm run register:dev\"",
    "build": "ts-node src/scripts/build.ts",
    "postbuild": "node src/scripts/sync-installed.mjs",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint 'src/**/*.{js,ts}'",
    "lint:fix": "eslint 'src/**/*.{js,ts}' --fix",
    "format": "prettier --write 'src/**/*.{js,ts,json}'",
    "register:dev": "node dist/scripts/register-dev.js",
    "docs:tools": "node scripts/generate-tools-doc.mjs",
    "postinstall": "node scripts/postinstall-guard.cjs",
    "prepublishOnly": "pnpm build"
  },
  "files": [
    "dist",
    "scripts/postinstall-guard.cjs",
    "!dist/node_path.txt"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "preferGlobal": true,
  "keywords": [
    "mcp",
    "model-context-protocol",
    "chrome",
    "chrome-extension",
    "browser-automation",
    "ai-agent",
    "claude",
    "playwright-alternative",
    "linkedin-automation",
    "whatsapp-automation",
    "humanchrome"
  ],
  "author": "Mihai Mateias",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.131",
    "@fastify/cors": "^11.0.1",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "@types/node-fetch": "2",
    "better-sqlite3": "^11.6.0",
    "chrome-devtools-frontend": "^1.0.1625079",
    "humanchrome-shared": "workspace:*",
    "commander": "^13.1.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.3.2",
    "is-admin": "^4.0.0",
    "node-fetch": "2",
    "pino": "^10.3.1",
    "pino-pretty": "^11.3.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/chrome": "^0.1.40",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.3",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/parser": "^8.59.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.1",
    "nodemon": "^3.1.10",
    "rimraf": "^6.0.1",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "ts-node": "^10.9.2"
  }
}
