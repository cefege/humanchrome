{
  "name": "humanchrome-shared",
  "version": "1.0.0",
  "private": true,
  "description": "Shared types and constants for HumanChrome.",
  "author": "Mihai Mateias",
  "license": "MIT",
  "homepage": "https://github.com/cefege/humanchrome",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cefege/humanchrome.git",
    "directory": "packages/shared"
  },
  "bugs": {
    "url": "https://github.com/cefege/humanchrome/issues"
  },
  "main": "dist/index.js",
  "module": "./dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "lint": "npx eslint 'src/**/*.{js,ts}'",
    "lint:fix": "npx eslint 'src/**/*.{js,ts}' --fix",
    "format": "prettier --write 'src/**/*.{js,ts,json}'"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/parser": "^8.59.2",
    "tsup": "^8.4.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.11.0",
    "zod": "^3.24.4"
  }
}
