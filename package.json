{
  "name": "humanchrome-monorepo",
  "version": "1.0.0",
  "private": true,
  "author": "Mihai Mateias",
  "license": "MIT",
  "description": "AI controls your real Chrome. Built for hard-to-automate platforms (LinkedIn, WhatsApp, Tinder, Facebook, Instagram). MCP and plain HTTP.",
  "homepage": "https://github.com/cefege/humanchrome",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cefege/humanchrome.git"
  },
  "bugs": {
    "url": "https://github.com/cefege/humanchrome/issues"
  },
  "type": "module",
  "scripts": {
    "build:shared": "pnpm --filter humanchrome-shared build",
    "build:native": "pnpm --filter humanchrome-bridge build",
    "build:extension": "pnpm --filter humanchrome-extension build",
    "build:wasm": "pnpm --filter @humanchrome/wasm-simd build && pnpm run copy:wasm",
    "build": "pnpm -r --filter='!@humanchrome/wasm-simd' build",
    "copy:wasm": "cp ./packages/wasm-simd/pkg/simd_math.js ./packages/wasm-simd/pkg/simd_math_bg.wasm ./app/chrome-extension/workers/",
    "dev:shared": "pnpm --filter humanchrome-shared dev",
    "dev:native": "pnpm --filter humanchrome-bridge dev",
    "dev:extension": "pnpm --filter humanchrome-extension dev",
    "dev": "pnpm --filter humanchrome-shared build && pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "format": "pnpm -r format",
    "clean:dist": "pnpm -r exec rm -rf dist .turbo",
    "clean:modules": "pnpm -r exec rm -rf node_modules && rm -rf node_modules",
    "clean": "pnpm clean:dist && pnpm clean:modules",
    "//typecheck": "Two filters: wasm-simd (Rust pkg, no tsconfig) AND humanchrome-monorepo (the workspace root, no tsconfig either — pnpm -r exec includes it).",
    "typecheck": "pnpm -r --filter='!@humanchrome/wasm-simd' --filter='!humanchrome-monorepo' exec tsc --noEmit",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-vue": "^10.9.1",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.59.2",
    "vue-eslint-parser": "^10.1.3"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "**/*.{json,md,yaml,html,css}": [
      "prettier --write"
    ]
  }
}
